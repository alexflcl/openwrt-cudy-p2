#!/bin/sh
set -e
. /lib/functions.sh

CONFIG_NAME="main"
LOCK_FILE="/var/run/p2modem.lock"

load_cfg() {
    config_load p2modem >/dev/null 2>&1 || true
    config_get ENABLED "$CONFIG_NAME" enabled "1"
    config_get APN "$CONFIG_NAME" apn "internet"
    config_get PDP_TYPE "$CONFIG_NAME" pdp_type "IP"
    config_get AT_PORT "$CONFIG_NAME" at_port "/dev/stty_nr31"
    config_get DATA_IF "$CONFIG_NAME" data_if "pcie0"
    config_get DUMMY_IF "$CONFIG_NAME" dummy_if "sipa_dummy0"
    config_get WWAN_IFACE "$CONFIG_NAME" wwan_iface "wwan"
    config_get METRIC "$CONFIG_NAME" metric "10"
    config_get WAN_MODE "$CONFIG_NAME" wan_mode "sim-primary"
    config_get RAT_PREF "$CONFIG_NAME" rat_pref "auto"
}

log() {
    logger -t p2modem "$*"
    printf '%s\n' "$*"
}

run_locked() {
    "$@"
}

capture_at() {
    local cmd="$1"
    local wait_s="${2:-2}"
    local tmp="/tmp/p2modem-at.$$"
    rm -f "$tmp"
    cat "$AT_PORT" > "$tmp" &
    local cpid=$!
    sleep 1
    printf '%s\r' "$cmd" > "$AT_PORT"
    sleep "$wait_s"
    kill "$cpid" >/dev/null 2>&1 || true
    wait "$cpid" 2>/dev/null || true
    tr -d '\000\r' < "$tmp"
    rm -f "$tmp"
}

at_ok() {
    local out
    out="$(capture_at "$1" "${2:-2}")"
    printf '%s\n' "$out"
    printf '%s\n' "$out" | grep -q 'OK'
}

at_query() {
    capture_at "$1" "${2:-3}" | sed '/^$/d'
}

json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

ensure_links() {
    ip link set "$DUMMY_IF" up 2>/dev/null || true
    ip link set "$DATA_IF" up 2>/dev/null || true
}

find_lan_device_section() {
    local lan_device
    local section

    lan_device="$(uci -q get network.lan.device 2>/dev/null || true)"
    if [ -z "$lan_device" ]; then
        echo "@device[0]"
        return 0
    fi

    for section in $(uci -q show network | sed -n 's/^network\.\([^.=]*\)=device$/\1/p'); do
        if [ "$(uci -q get "network.$section.name" 2>/dev/null || true)" = "$lan_device" ]; then
            echo "$section"
            return 0
        fi
    done

    echo "@device[0]"
}

set_lan_ports() {
    local section="$1"
    shift

    uci -q delete "network.$section.ports"
    while [ "$#" -gt 0 ]; do
        uci add_list "network.$section.ports=$1"
        shift
    done
}

ensure_wwan_network() {
    uci set "network.${WWAN_IFACE}=interface"
    uci set "network.${WWAN_IFACE}.proto=dhcp"
    uci set "network.${WWAN_IFACE}.device=$DATA_IF"
    uci set "network.${WWAN_IFACE}.auto=1"
    uci set "network.${WWAN_IFACE}.defaultroute=1"
    uci set "network.${WWAN_IFACE}.metric=$METRIC"
}

ensure_wwan_firewall() {
    local zone=""
    local networks

    for zone in $(uci -q show firewall | sed -n 's/^firewall\.\([^.=]*\)=zone$/\1/p'); do
        if [ "$(uci -q get "firewall.$zone.name" 2>/dev/null || true)" = "wan" ]; then
            break
        fi
        zone=""
    done

    [ -n "$zone" ] || return 0

    networks="$(uci -q get "firewall.$zone.network" 2>/dev/null || true)"
    case " $networks " in
        *" $WWAN_IFACE "*) ;;
        *) uci add_list "firewall.$zone.network=$WWAN_IFACE" ;;
    esac
}

recycle_iface() {
    local ifn="$1"
    ifdown "$ifn" 2>/dev/null || true
    sleep 1
    ifup "$ifn" 2>/dev/null || true
}

get_temp_c() {
    local path="$1"
    [ -f "$path" ] || return 0
    awk '{ printf "%.1f", $1 / 1000 }' "$path"
}

show_temps() {
    echo "[TEMPS]"
    printf 'cpu=%s C\n' "$(get_temp_c /sys/class/thermal/thermal_zone0/temp)"
    printf 'wifi_2g=%s C\n' "$(get_temp_c /sys/class/hwmon/hwmon1/temp1_input)"
    printf 'wifi_5g=%s C\n' "$(get_temp_c /sys/class/hwmon/hwmon2/temp1_input)"
}

show_board_info() {
    echo "[BOARD]"
    ubus call system board 2>/dev/null || true
}

show_modem_ports() {
    echo "[MODEM_PORTS]"
    ls -l /dev/stty_nr31 /dev/ttyUSB0 /dev/ttyUSB1 /dev/ttyUSB2 /dev/ttyUSB3 /dev/ttyUSB4 2>/dev/null || true
}

show_net_links() {
    echo "[NET_LINKS]"
    ip -br link 2>/dev/null || true
}

show_port_status() {
    echo "[PORT_STATUS]"

    echo "### LAN ###"
    ifstatus lan 2>/dev/null || {
        echo "device=br-lan"
        ip -br addr show br-lan 2>/dev/null || true
    }
    echo

    echo "### WAN ###"
    ifstatus wan 2>/dev/null || true
    echo

    echo "### WAN6 ###"
    ifstatus wan6 2>/dev/null || true
    echo

    echo "### WWAN ###"
    ifstatus "$WWAN_IFACE" 2>/dev/null || true
}

show_active_dns() {
    echo "[DNS]"
    sed -n '1,20p' /tmp/resolv.conf.d/resolv.conf.auto 2>/dev/null || true
}

show_modem_runtime() {
    local out

    echo "[MODEM_SIM]"
    out="$(at_query 'AT+CPIN?' 2)"
    printf '%s\n' "$out" | grep -E '^\+CPIN:' || true
    out="$(at_query 'AT+QCCID' 2)"
    printf '%s\n' "$out" | grep -E '^\+QCCID:' || true
    echo

    echo "[MODEM_OPERATOR]"
    out="$(at_query 'AT+QSPN' 2)"
    printf '%s\n' "$out" | grep -E '^\+QSPN:' || true
    out="$(at_query 'AT+COPS?' 2)"
    printf '%s\n' "$out" | grep -E '^\+COPS:' || true
    echo

    echo "[MODEM_SIGNAL]"
    out="$(at_query 'AT+CSQ' 2)"
    printf '%s\n' "$out" | grep -E '^\+CSQ:' || true
    echo

    echo "[MODEM_NETWORK]"
    out="$(at_query 'AT+QNWINFO' 3)"
    printf '%s\n' "$out" | grep -E '^\+QNWINFO:' || true
    echo

    echo "[MODEM_SERVING_CELL]"
    out="$(at_query 'AT+QENG="servingcell"' 3)"
    printf '%s\n' "$out" | grep -E '^\+QENG:' || true
    echo

    echo "[MODEM_CAINFO]"
    out="$(at_query 'AT+QCAINFO' 3)"
    printf '%s\n' "$out" | grep -E '^\+QCAINFO:' || true
}

summary_impl() {
    load_cfg

    local board_json sim_ready sim_id operator_qspn operator_cops csq qnwinfo
    local qeng qca lte_line nr_line wwan_json wwan_ip dns uptime route_dev cpu_temp wifi2g_temp wifi5g_temp
    local operator technology ca_summary rssi rsrp rsrq sinr oldifs

    board_json="$(ubus call system board 2>/dev/null || echo '{}')"
    sim_ready="$(at_query 'AT+CPIN?' 1 | sed -n 's/.*+CPIN: *//p' | head -n1)"
    sim_id="$(at_query 'AT+QCCID' 1 | sed -n 's/.*+QCCID: *//p' | head -n1)"
    operator_qspn="$(at_query 'AT+QSPN' 1 | sed -n 's/.*+QSPN: *\"\([^\"]*\)\".*/\1/p' | head -n1)"
    operator_cops="$(at_query 'AT+COPS?' 1 | sed -n 's/.*+COPS: [^,]*,[^,]*,\"\([^\"]*\)\".*/\1/p' | head -n1)"
    [ -n "$operator_qspn" ] && operator="$operator_qspn" || operator="$operator_cops"
    csq="$(at_query 'AT+CSQ' 1 | sed -n 's/.*+CSQ: *\([0-9]*\).*/\1/p' | head -n1)"
    qnwinfo="$(at_query 'AT+QNWINFO' 1 | grep '^\+QNWINFO:' || true)"
    qeng="$(at_query 'AT+QENG=\"servingcell\"' 2 | grep '^\+QENG:' || true)"
    qca="$(at_query 'AT+QCAINFO' 2 | grep '^\+QCAINFO:' || true)"

    lte_line="$(printf '%s\n' "$qeng" | grep '^\+QENG: "LTE"' | head -n1 || true)"
    nr_line="$(printf '%s\n' "$qeng" | grep '^\+QENG: "NR5G' | head -n1 || true)"

    oldifs="$IFS"
    if [ -n "$lte_line" ]; then
        IFS=','
        set -- $lte_line
        IFS="$oldifs"
        rssi="$(printf '%s' "${12:-}" | tr -d '"')"
        rsrq="$(printf '%s' "${13:-}" | tr -d '"')"
        rsrp="$(printf '%s' "${14:-}" | tr -d '"')"
    fi
    if [ -n "$nr_line" ]; then
        IFS=','
        set -- $nr_line
        IFS="$oldifs"
        sinr="$(printf '%s' "${6:-}" | tr -d '"')"
    fi

    technology="$(printf '%s\n' "$qnwinfo" | awk -F'\"' '/^\+QNWINFO:/ { if (out) out=out " + "; out=out $2 " | " $6 } END { print out }')"
    if [ -z "$technology" ]; then
        technology=""
        printf '%s\n' "$qeng" | grep -q '^\+QENG: "LTE"' && technology="LTE"
        if printf '%s\n' "$qeng" | grep -q '^\+QENG: "NR5G-NSA"'; then
            if [ -n "$technology" ]; then
                technology="$technology + NR5G-NSA"
            else
                technology="NR5G-NSA"
            fi
        fi
    fi
    ca_summary="$(printf '%s\n' "$qca" | awk -F'\"' '/^\+QCAINFO:/ { if (out) out=out " + "; out=out $2 " " $6 } END { print out }')"

    wwan_json="$(ifstatus "$WWAN_IFACE" 2>/dev/null || echo '{}')"
    wwan_ip="$(printf '%s' "$wwan_json" | jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null || true)"
    dns="$(printf '%s' "$wwan_json" | jsonfilter -e '@["dns-server"][0]' -e '@["dns-server"][1]' 2>/dev/null | tr '\n' ',' | sed 's/,$//; s/,/, /g')"
    uptime="$(printf '%s' "$wwan_json" | jsonfilter -e '@.uptime' 2>/dev/null || true)"
    route_dev="$(printf '%s' "$wwan_json" | jsonfilter -e '@.l3_device' 2>/dev/null || true)"

    cpu_temp="$(get_temp_c /sys/class/thermal/thermal_zone0/temp)"
    wifi2g_temp="$(get_temp_c /sys/class/hwmon/hwmon1/temp1_input)"
    wifi5g_temp="$(get_temp_c /sys/class/hwmon/hwmon2/temp1_input)"

    cat <<EOF
{
  "model": "$(json_escape "$(printf '%s' "$board_json" | jsonfilter -e '@.model' 2>/dev/null || echo Cudy\ P2)")",
  "operator": "$(json_escape "$operator")",
  "technology": "$(json_escape "$technology")",
  "carrier_aggregation": "$(json_escape "$ca_summary")",
  "sim_status": "$(json_escape "$sim_ready")",
  "iccid": "$(json_escape "$sim_id")",
  "csq": "$(json_escape "$csq")",
  "rssi": "$(json_escape "$rssi")",
  "rsrp": "$(json_escape "$rsrp")",
  "rsrq": "$(json_escape "$rsrq")",
  "sinr": "$(json_escape "$sinr")",
  "cpu_temp": "$(json_escape "$cpu_temp")",
  "wifi2g_temp": "$(json_escape "$wifi2g_temp")",
  "wifi5g_temp": "$(json_escape "$wifi5g_temp")",
  "wwan_ip": "$(json_escape "$wwan_ip")",
  "dns": "$(json_escape "$dns")",
  "route_device": "$(json_escape "$route_dev")",
  "uptime": "$(json_escape "$uptime")"
}
EOF
}

apply_rat_pref() {
    case "$RAT_PREF" in
        4g|lte)
            at_ok 'AT+QCFG="nwscanmode",3,1' 3 >/tmp/p2modem.last 2>&1 || true
            at_ok 'AT+QCFG="iotopmode",0' 2 >/tmp/p2modem.last 2>&1 || true
            log "Preferencia radio aplicada: 4G"
            ;;
        5g|nr)
            at_ok 'AT+QCFG="nwscanmode",3,1' 3 >/tmp/p2modem.last 2>&1 || true
            at_ok 'AT+QCFG="nr5g_disable_mode",0' 3 >/tmp/p2modem.last 2>&1 || true
            log "Preferencia radio aplicada: 5G"
            ;;
        auto|*)
            at_ok 'AT+QCFG="nwscanmode",0,1' 3 >/tmp/p2modem.last 2>&1 || true
            log "Preferencia radio aplicada: auto"
            ;;
    esac
}

connect_impl() {
    load_cfg
    [ "$ENABLED" = "1" ] || { log "P2 modem desactivado"; exit 1; }
    [ -c "$AT_PORT" ] || { log "Puerto AT no encontrado: $AT_PORT"; exit 1; }
    [ -d "/sys/class/net/$DATA_IF" ] || { log "Interfaz de datos no encontrada: $DATA_IF"; exit 1; }

    ensure_wwan_network
    uci commit network
    ensure_wwan_firewall
    uci commit firewall
    /etc/init.d/firewall reload >/dev/null 2>&1 || true

    local out
    out="$(capture_at 'AT' 2)"
    printf '%s\n' "$out" | grep -q 'OK' || { log "El modem no responde por $AT_PORT"; exit 1; }
    out="$(capture_at 'AT+CPIN?' 2)"
    printf '%s\n' "$out" | grep -q '+CPIN: READY' || { printf '%s\n' "$out"; log "La SIM no esta lista"; exit 1; }
    at_ok "AT+CGDCONT=1,\"$PDP_TYPE\",\"$APN\"" 2 >/tmp/p2modem.last 2>&1 || true
    at_ok "AT+QICSGP=1,1,\"$APN\",\"\",\"\",0" 3 >/tmp/p2modem.last 2>&1 || true
    apply_rat_pref || true
    at_ok 'AT+QNETDEVCTL=1,1,1' 3 >/tmp/p2modem.last 2>&1 || {
        cat /tmp/p2modem.last 2>/dev/null || true
        log "No se pudo activar la sesion de datos"
        exit 1
    }

    ensure_links
    recycle_iface "$WWAN_IFACE"
    sleep 6
    if ifstatus "$WWAN_IFACE" 2>/dev/null | grep -q '"up": true'; then
        log "WWAN conectada por $DATA_IF (modo $WAN_MODE, rat $RAT_PREF)"
        return 0
    fi

    log "La interfaz $WWAN_IFACE no ha levantado"
    ifstatus "$WWAN_IFACE" 2>/dev/null || true
    exit 1
}

disconnect_impl() {
    load_cfg
    ifdown "$WWAN_IFACE" 2>/dev/null || true
    capture_at 'AT+QNETDEVCTL=1,0,1' 3 >/tmp/p2modem.last 2>&1 || true
    ip addr flush dev "$DATA_IF" 2>/dev/null || true
    ip link set "$DATA_IF" down 2>/dev/null || true
    ip link set "$DUMMY_IF" down 2>/dev/null || true
    log "WWAN desconectada"
}

apply_mode_impl() {
    local mode="${1:-}"
    local lan_section

    [ -n "$mode" ] || { echo "Falta modo"; exit 1; }

    load_cfg
    lan_section="$(find_lan_device_section)"
    ensure_wwan_network
    ensure_wwan_firewall

    case "$mode" in
        sim-primary)
            uci set p2modem.main.metric='10'
            uci set p2modem.main.wan_mode='sim-primary'
            set_lan_ports "$lan_section" 'lan'
            uci set network.wan.metric='30'
            uci set network.wan6.metric='30'
            uci set network.wan.auto='1'
            uci set network.wan6.auto='1'
            uci set network.wwan.metric='10'
            uci set network.wwan.auto='1'
            uci set network.wwan.defaultroute='1'
            ;;
        wan-primary)
            uci set p2modem.main.metric='20'
            uci set p2modem.main.wan_mode='wan-primary'
            set_lan_ports "$lan_section" 'lan'
            uci set network.wan.metric='10'
            uci set network.wan6.metric='10'
            uci set network.wan.auto='1'
            uci set network.wan6.auto='1'
            uci set network.wwan.metric='20'
            uci set network.wwan.auto='1'
            uci set network.wwan.defaultroute='1'
            ;;
        wan-as-lan)
            uci set p2modem.main.metric='10'
            uci set p2modem.main.wan_mode='wan-as-lan'
            set_lan_ports "$lan_section" 'lan' 'wan'
            uci set network.wan.auto='0'
            uci set network.wan6.auto='0'
            uci set network.wwan.metric='10'
            uci set network.wwan.auto='1'
            uci set network.wwan.defaultroute='1'
            ;;
        4g|lte)
            uci set p2modem.main.rat_pref='4g'
            RAT_PREF='4g'
            uci commit p2modem
            apply_rat_pref || true
            ;;
        5g|nr)
            uci set p2modem.main.rat_pref='5g'
            RAT_PREF='5g'
            uci commit p2modem
            apply_rat_pref || true
            ;;
        auto)
            uci set p2modem.main.rat_pref='auto'
            RAT_PREF='auto'
            uci commit p2modem
            apply_rat_pref || true
            ;;
        *)
            echo "Modo no soportado: $mode"
            exit 1
            ;;
    esac

    case "$mode" in
        sim-primary|wan-primary|wan-as-lan)
            uci commit p2modem
            uci commit network
            uci commit firewall
            /etc/init.d/firewall reload >/dev/null 2>&1 || true
            /etc/init.d/network reload >/dev/null 2>&1 || true
            if [ "$mode" = "wan-as-lan" ]; then
                ifdown wan 2>/dev/null || true
                ifdown wan6 2>/dev/null || true
                ip route del default dev wan 2>/dev/null || true
            else
                recycle_iface wan
            fi
            recycle_iface "$WWAN_IFACE"
            sleep 6
            ;;
    esac

    if ! ifstatus "$WWAN_IFACE" 2>/dev/null | grep -q '"up": true'; then
        connect_impl || true
    fi

    log "Modo WAN aplicado: $mode"
}

status_impl() {
    load_cfg
    echo "enabled=$ENABLED"
    echo "apn=$APN"
    echo "pdp_type=$PDP_TYPE"
    echo "at_port=$AT_PORT"
    echo "data_if=$DATA_IF"
    echo "dummy_if=$DUMMY_IF"
    echo "wwan_iface=$WWAN_IFACE"
    echo "metric_config=$METRIC"
    echo "wan_mode=$WAN_MODE"
    echo "rat_pref=$RAT_PREF"
    echo
    show_board_info
    echo
    show_temps
    echo
    show_modem_ports
    echo
    show_modem_runtime
    echo
    show_port_status
    echo
    show_net_links
    echo
    echo "[BRIDGE_PORTS]"
    uci get "network.$(find_lan_device_section).ports" 2>/dev/null || true
    echo
    echo "[ACTIVE_ROUTE]"
    ip route get 1.1.1.1 2>/dev/null || true
    echo
    show_active_dns
    echo
    echo "[ROUTES]"
    ip route
}

probe_impl() {
    load_cfg
    for p in /dev/stty_nr31 /dev/stty_nr* /dev/ttyUSB2 /dev/ttyUSB0 /dev/ttyUSB1 /dev/ttyUSB3 /dev/ttyUSB4; do
        [ -e "$p" ] || continue
        AT_PORT="$p"
        echo "=== $p ==="
        capture_at 'AT' 2 || true
        echo
    done
}

case "${1:-status}" in
    connect) run_locked connect_impl ;;
    disconnect) run_locked disconnect_impl ;;
    summary) run_locked summary_impl ;;
    status) run_locked status_impl ;;
    probe) run_locked probe_impl ;;
    temps) run_locked show_temps ;;
    apply-mode) run_locked apply_mode_impl "${2:-}" ;;
    *) echo "Uso: $0 {connect|disconnect|summary|status|probe|temps|apply-mode <sim-primary|wan-primary|wan-as-lan|4g|5g|auto>}"; exit 1 ;;
esac
